{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PoprawiaczTekstu",
  "version": "0.1.0",
  "identifier": "pl.tlsystems.poprawiacz",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PoprawiaczTekstu",
        "width": 1100,
        "height": 760,
        "minWidth": 720,
        "minHeight": 520,
        "resizable": true,
        "center": true,
        "visible": true,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  },
  "plugins": {}
}
